# =============================================================================
# LLM Provider — pick ONE of the three modes below, leave the others blank
# =============================================================================

# --- MODE 1: Azure OpenAI (default for this project) ---
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_DEPLOYMENT_NAME=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-02-01

# --- MODE 2: Standard OpenAI API key ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# --- MODE 3: OpenRouter (or any OpenAI-compatible endpoint) ---
# OPENAI_API_KEY=sk-or-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=openai/gpt-4o

# =============================================================================
# Payment API (no changes needed)
# =============================================================================
PAYMENT_API_BASE_URL=https://se-payment-verification-api.service.external.usea2.aws.prodigaltech.com
API_TIMEOUT_SECONDS=10
API_MAX_RETRIES=3

# =============================================================================
# Agent behavior
# =============================================================================
MAX_VERIFICATION_ATTEMPTS=3
HISTORY_WINDOW_TURNS=12
EXTRACTION_TEMPERATURE=0.0
RESPONSE_TEMPERATURE=0.3
RESPONSE_MAX_TOKENS=350
